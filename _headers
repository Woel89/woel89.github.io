# Cloudflare Pages _headers
# Документация: https://developers.cloudflare.com/pages/configuration/headers/

/games.json
  Cache-Control: no-store

/index.html
  Cache-Control: no-store

/my/*
  Cache-Control: no-store

/games/*
  Cache-Control: no-store
  Content-Security-Policy: frame-src https://builds.netgameforge.com https://html5.gamemonetize.co https://*.gamemonetize.co https://gamedistribution.com https://*.gamedistribution.com

/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable

/assets/covers/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=300, must-revalidate

/js/*
  Cache-Control: public, max-age=300, must-revalidate
